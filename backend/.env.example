# #  Production
# # MSSQL_SERVER=
# # MSSQL_USER=
# # MSSQL_PASSWORD=
# # MSSQL_DATABASE=
# # DB_MAX_CONNS=
# # DB_MIN_CONNS=
# # USERS_DATABASE=

# # Local
# MSSQL_SERVER=
# MSSQL_USER=
# MSSQL_PASSWORD=
# MSSQL_DATABASE=
# DB_MAX_CONNS=
# DB_MIN_CONNS=
# USERS_DATABASE=

# # ── AUTH DB (SEPARATE, WRITABLE PostgreSQL we control) ─────────────────────
# # The company account is READ-ONLY (cannot CREATE TABLE), so auth tables live in
# # our own Postgres. Set AUTH_DATABASE_URL, OR the discrete AUTH_PG_* below, OR
# # rely on standard PG* env vars. Build the schema with postgres-sql/setup_local.sh.
# # Percent-encode special chars in the password (e.g. > ? * -> %3E %3F %2A).
# AUTH_DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/renewal_auth?sslmode=disable
# # Discrete alternative (used only if AUTH_DATABASE_URL is unset):
# # AUTH_PG_HOST=127.0.0.1
# # AUTH_PG_PORT=5432
# # AUTH_PG_USER=postgres
# # AUTH_PG_PASSWORD=
# # AUTH_PG_DATABASE=renewal_auth
# AUTH_DB_MAX_CONNS=5

# # JWT — REQUIRED. App refuses to boot if unset/short. Generate: openssl rand -hex 32
# AUTH_JWT_SECRET=
# AUTH_ACCESS_TTL_MIN=60
# AUTH_REFRESH_TTL_DAYS=14

# # Bootstrap super admin (used only by `python seed.py --seed`)
# AUTH_BOOTSTRAP_USER=superadmin
# AUTH_BOOTSTRAP_PASSWORD=

# # CORS — comma-separated allowed origins for the SPA
# AUTH_CORS_ORIGINS=http://localhost:4200



#  Production
# MSSQL_SERVER=172.31.21.121
# MSSQL_USER=ai_dev
# MSSQL_PASSWORD=dev@123
# MSSQL_DATABASE=probus_autoboat_live
# DB_MAX_CONNS=15
# DB_MIN_CONNS=2
# USERS_DATABASE=probus_web_live

# Local
MSSQL_SERVER=127.0.0.2,10067
MSSQL_USER=ai_dev
MSSQL_PASSWORD=dev@123
MSSQL_DATABASE=probus_autoboat_live
DB_MAX_CONNS=15
DB_MIN_CONNS=2
USERS_DATABASE=probus_web_live

# ── AUTH DB (PostgreSQL) ───────────────────────────────────────────────────
# Password is percent-encoded in the URL (> ? * -> %3E %3F %2A); psycopg decodes it.
# Dropped &timezone=UTC — libpq rejects it as a param; our timestamps use AT TIME ZONE 'utc'.
# testing
AUTH_DATABASE_URL=postgres://admin_user:N96wS%3E80%3FM%2AR@15.206.192.126:5432/renewal_auth?sslmode=disable
# production
# AUTH_DATABASE_URL="postgres://admin_user:N96wS%3E80%3FM%2AR@10.20.0.86/renewal_auth?sslmode=disable&timezone=UTC"
AUTH_DB_MAX_CONNS=5
AUTH_JWT_SECRET=fixed_test_secret_at_least_32_chars_long_xxxx
AUTH_ACCESS_TTL_MIN=60
AUTH_REFRESH_TTL_DAYS=14
AUTH_BOOTSTRAP_USER=superadmin
AUTH_BOOTSTRAP_PASSWORD=Admin@12345
AUTH_CORS_ORIGINS=http://localhost:4200


